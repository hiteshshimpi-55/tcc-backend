# Application
APP_NAME=tcc-backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL for LangGraph checkpoints)
DATABASE_URL=postgresql://tcc:tcc@localhost:5432/tcc

# LLM (OpenAI)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# LangSmith tracing (optional — set LANGCHAIN_TRACING_V2=true to enable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=tcc-backend

# Security (optional — if set, agent routes require X-API-Key header)
API_KEY=
